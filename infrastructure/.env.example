# Copy this file to .env and fill in your values.
# Never commit the .env file.

# Required: min 32-char random string (e.g. openssl rand -base64 32)
JWT_SECRET=change-me-to-a-long-random-secret

# Required: YouTube Data API v3 key from Google Cloud Console
YOUTUBE_API_KEY=

# Optional: at least one LLM key enables AI Insights (Creator tier feature)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Production only: PostgreSQL password for the prod database
POSTGRES_PASSWORD=change-me-in-production
