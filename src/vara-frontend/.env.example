# Copy to .env.local for local development overrides.
# These are set at build time (baked into the JS bundle).

# API base URL — only needed when running the frontend outside the Docker Compose stack.
# In dev, the Vite proxy handles /api → http://localhost:5000 automatically.
# In production Docker Compose, the Node adapter uses the proxy config in svelte.config.js.
# VITE_API_BASE_URL=http://localhost:5000
